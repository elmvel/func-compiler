let scaleA: int [x: int] :=
    x * 10
end

let scaleB: int [x: int] :=
    x * 37
end

let mainZ: int [] :=
    (scaleA 14) + (scaleB 34)
end

let main: int [] :=
    (scaleB (scaleA (scaleB 34))) + (scaleA (scaleB (scaleA 35)))
end